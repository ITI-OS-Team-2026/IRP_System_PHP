# Application
BASE_URL=https://your-app.up.railway.app
APP_BASE_URL=

# Database Configuration (Aiven)
DB_CONNECTION=mysql
DB_HOST=your-db-host.aivencloud.com
DB_PORT=14210
DB_DATABASE=defaultdb
DB_USERNAME=avnadmin
DB_PASSWORD=''
DB_SSL_MODE=REQUIRED

# Paymob Credentials
# Intention API (for Card payments)
PAYMOB_SECRET_KEY=your_secret_key_here
PAYMOB_PUBLIC_KEY=your_public_key_here
# Classic API (for Wallet payments)
PAYMOB_API_KEY=your_classic_api_key_here

# Paymob Integration IDs
PAYMOB_WALLET_INTEGRATION_ID=5633494
PAYMOB_CARD_INTEGRATION_ID=5633391
PAYMOB_HMAC_SECRET=your_hmac_secret

# Payment Configuration
INITIAL_PAYMENT_AMOUNT=500
CURRENCY=EGP

# Webhook Configuration
# Leave WEBHOOK_BASE_URL empty to auto-derive from BASE_URL
WEBHOOK_BASE_URL=
WEBHOOK_ENDPOINT=/payment/webhook
RECEIPT_ENDPOINT=/payment/receipt
